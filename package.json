{
  "name": "simple-voice-changer",
  "version": "2.3.2",
  "private": false,
  "scripts": {
    "dev": "npm run copy-worklets-worklets && next dev --webpack",
    "build": "next build --webpack",
    "start": "next start --webpack",
    "lint": "next lint",
    "test": "npx playwright test",
    "prebuild": "npm run copy-worklets-worklets",
    "copy-worklets-worklets": "mkdir -p public/worklets public/workers && cp node_modules/@eliastik/simple-sound-studio-lib/dist/worklets/*.js public/worklets/ && cp node_modules/@eliastik/simple-sound-studio-lib/dist/workers/*.js public/workers/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eliastik/simple-voice-changer.git"
  },
  "dependencies": {
    "@eliastik/simple-sound-studio-components": "^2.3.2",
    "@eliastik/simple-sound-studio-lib": "^2.3.2",
    "i18next": "^25.8.13",
    "lodash": "^4.17.23",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "semver": "^7.7.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/audioworklet": "^0.0.75",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "autoprefixer": "^10.4.24",
    "daisyui": "^5.5.19",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react": "^7.37.5",
    "glob": "^13.0.6",
    "next-pwa": "^5.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
